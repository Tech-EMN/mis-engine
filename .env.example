# MIS Engine — Environment Variables
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Railway (production): these are set as service variables via
#   railway variable upsert or dashboard → Environment Variables.
# Local development: create .env from this template.

# === Supabase (LugOn — Grupo AD) ===
# Required for database persistence
SUPABASE_LUG_URL=<sua-url-do-supabase>
SUPABASE_LUG_SECRET_KEY=<sua-chave-secreta>

# === Supabase (Account — DDL/admin only) ===
# Required only for schema migrations (CREATE TABLE, etc.)
# NOT needed for normal CRUD operations
SUPABASE_ACCESS_TOKEN=<sbp_...-personal-access-token>

# === Anthropic Claude (AI Vision) ===
# Required for PDF extraction (Vision LLM analyzes plant images)
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# === Optional ===
# Path to secrets file (local dev only — not needed on Railway)
# MIS_SECRETS_PATH=/etc/secrets/mis-secrets.json
